<?php
$error = "";
$output = "";

if (isset($_POST["submit"])) {
    // Step 1: Get inputs
    $name    = trim($_POST["name"] ?? "");
    $email   = trim($_POST["email"] ?? "");
    $gender  = $_POST["gender"] ?? "";
    $course  = $_POST["course"] ?? "";
    $hobbies = $_POST["hobbies"] ?? [];
    $message = trim($_POST["message"] ?? "");

    // --------------------------
    // Step 2: VALIDATION
    // --------------------------
    if (empty($name))                     $error .= "• Name is required<br>";
    if (empty($email))                    $error .= "• Email is required<br>";
    elseif (!filter_var($email, FILTER_VALIDATE_EMAIL))
                                          $error .= "• Email format is invalid<br>";
    if (empty($gender))                   $error .= "• Gender is required<br>";
    if (empty($course))                   $error .= "• Please select a course<br>";
    if (empty($hobbies))                  $error .= "• Select at least one hobby<br>";
    if (empty($message))                  $error .= "• Message is required<br>";

    // --------------------------
    // Step 3: If NO errors → SANITIZE & SHOW
    // --------------------------
    if ($error === "") {
        $name    = htmlspecialchars($name);
        $email   = htmlspecialchars($email);
        $gender  = htmlspecialchars($gender);
        $course  = htmlspecialchars($course);
        $message = htmlspecialchars($message);

        $hobbyList = implode(", ", array_map('htmlspecialchars', $hobbies));

        $output = "
        <div style='background:#e8f4f8; padding:15px; border-radius:5px;'>
            <h3> Registration Successful</h3>
            <strong>Name:</strong> $name <br>
            <strong>Email:</strong> $email <br>
            <strong>Gender:</strong> $gender <br>
            <strong>Course:</strong> $course <br>
            <strong>Hobbies:</strong> $hobbyList <br>
            <strong>Message:</strong><br> " . nl2br($message) . "
        </div>";
    }
}
?>

